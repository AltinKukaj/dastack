# =============================================================================
# Environment template for dastack
# =============================================================================
# 1. Copy this file to `.env`:  cp .env.example .env   (or Copy-Item on Windows)
# 2. Fill in your values below. Never commit `.env`.
# 3. Core auth needs all three: DATABASE_URL, BETTER_AUTH_SECRET, BETTER_AUTH_URL.
#    Everything else is optional and turns on specific features.
# =============================================================================

# -----------------------------------------------------------------------------
# Core app + auth (required for auth and dashboard)
# Set all three to enable sign-in, dashboard, and protected routes.
# -----------------------------------------------------------------------------
# PostgreSQL connection string. Local: postgresql://USER:PASSWORD@localhost:5432/DB?schema=public
# Managed DBs: Neon, Supabase, Railway, etc. give you a connection URL in their dashboard.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dastack?schema=public

# Used to sign sessions and tokens. Generate with:  openssl rand -base64 32
# (PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }) -as [byte[]]))
BETTER_AUTH_SECRET=replace_with_openssl_rand_base64_32

# Base URL of your app. Dev: http://localhost:3000  ·  Prod: https://create.dagrate.xyz
# Used for OAuth callbacks, Stripe redirects, and absolute URLs in emails.
BETTER_AUTH_URL=http://localhost:3000

# Public URL for client-side code and metadata (sitemap, robots, etc.).
# Usually same as BETTER_AUTH_URL. In production, set to your app domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Email (Resend) – optional
# Enables: magic link sign-in, verification email, password reset email.
# -----------------------------------------------------------------------------
# Get key: https://resend.com → Sign up → API Keys → Create API Key → copy (starts with re_)
# Dev: Resend’s test domain only delivers to the email you signed up with.
# Prod: Add your domain in Resend → Domains and set EMAIL_FROM to use it.
RESEND_API_KEY=
# Sender shown in emails. Dev default: dastack <onboarding@resend.dev>
EMAIL_FROM=dastack <noreply@create.dagrate.xyz>

# -----------------------------------------------------------------------------
# OAuth providers – optional
# Callback URL for each: {BETTER_AUTH_URL}/api/auth/callback/{provider}
# e.g. http://localhost:3000/api/auth/callback/discord
# Add that exact URL in each provider’s app settings.
# -----------------------------------------------------------------------------
# Discord: https://discord.com/developers/applications → New Application → OAuth2 → Client ID & Secret
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Google: https://console.cloud.google.com/apis/credentials → Create OAuth 2.0 Client ID (Web app)
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers → New OAuth App
# Authorization callback URL: {BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Passkeys (WebAuthn) – optional override
# Passkeys are ON by default when auth is enabled. Set to true to disable
# (no passkey sign-in or passkey management in Settings).
# -----------------------------------------------------------------------------
# DISABLE_PASSKEY=true

# -----------------------------------------------------------------------------
# Stripe – optional
# Enables: /pricing, /dashboard/billing, checkout, and subscription flows.
# -----------------------------------------------------------------------------
# Get keys: https://dashboard.stripe.com/apikeys (Secret key sk_..., Publishable key pk_...)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Webhook secret for Stripe events (checkout completed, subscription updated, etc.)
# Get it: https://dashboard.stripe.com/webhooks → Add endpoint → {BETTER_AUTH_URL}/api/auth/stripe/webhook → Reveal signing secret (whsec_...)
# Local dev without ngrok: use any placeholder (e.g. whsec_local); run `bun stripe:poll` for local events.
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Captcha (Cloudflare Turnstile) – optional
# Enables Turnstile widget on sign-in/sign-up to reduce bots.
# -----------------------------------------------------------------------------
# Get keys: https://dash.cloudflare.com → Turnstile → Add widget → copy Site key and Secret key
# Localhost note: captcha is disabled by default on localhost to avoid domain/widget mismatch during local dev.
# To test captcha locally, allow localhost in your Turnstile widget and set ENABLE_CAPTCHA_ON_LOCALHOST=true.
CAPTCHA_SECRET_KEY=
NEXT_PUBLIC_CAPTCHA_SITE_KEY=
# ENABLE_CAPTCHA_ON_LOCALHOST=true

# Optional hard override for any environment:
# DISABLE_CAPTCHA=true

# -----------------------------------------------------------------------------
# CI / Docker – optional
# Set SKIP_ENV_VALIDATION=1 when .env is not available (e.g. CI, Docker build).
# Avoid using in local dev so missing vars are caught early.
# -----------------------------------------------------------------------------
# SKIP_ENV_VALIDATION=1
