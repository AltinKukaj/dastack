# ==============================================================================
# Environment variables example
# ==============================================================================
# Use this file as a template for your `.env` file.
# See DOCS/environment.md for details and setup notes.
# Never commit your real secrets.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application settings (Required)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# Database (Required)
# ------------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/app_template"

# ------------------------------------------------------------------------------
# Authentication (Required)
# ------------------------------------------------------------------------------
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="your_secure_random_string_here"

# ------------------------------------------------------------------------------
# OAuth providers (Optional)
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"

DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_CLIENT_SECRET="your_discord_client_secret"

# ------------------------------------------------------------------------------
# Email delivery (Optional)
# The default implementation uses Resend in `lib/email.ts`.
# ------------------------------------------------------------------------------
RESEND_API_KEY="re_abc123_your_resend_api_key"
EMAIL_FROM="Template <noreply@example.com>"

# ------------------------------------------------------------------------------
# Payments - Stripe (Optional)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_secret"
# After adding Stripe keys:
# 1. Edit `lib/plans.ts` if needed
# 2. Run `pnpm stripe:sync`
# 3. Restart the dev server
# 4. Run `pnpm stripe:poll` locally if you are not forwarding webhooks

# ------------------------------------------------------------------------------
# Feature flags (Optional)
# Any of these can be set to `true`, `1`, `yes`, or `on`.
# ------------------------------------------------------------------------------
ENABLE_ORGANIZATIONS="true"
ENABLE_ADMIN_PANEL="true"

# ------------------------------------------------------------------------------
# File uploads - UploadThing (Optional)
# ------------------------------------------------------------------------------
UPLOADTHING_TOKEN="sg_your_uploadthing_token"

# ------------------------------------------------------------------------------
# Redis cache configuration (Optional)
# ------------------------------------------------------------------------------
ENABLE_REDIS_CACHE="true"
REDIS_URL="redis://default:password@localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD="your_redis_password_if_any"
REDIS_DB="0"
REDIS_KEY_PREFIX="app"
REDIS_STRICT_MODE="true"
